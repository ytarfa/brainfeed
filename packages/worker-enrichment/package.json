{
  "name": "@brain-feed/worker-enrichment",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "start": "ts-node --transpile-only src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pipeline": "ts-node --transpile-only src/test-pipeline.ts"
  },
  "dependencies": {
    "@brain-feed/types": "workspace:*",
    "@brain-feed/worker-core": "workspace:*",
    "@langchain/community": "^1.1.25",
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openrouter": "^0.1.8",
    "@supabase/supabase-js": "^2.100.1",
    "bullmq": "^5.71.1",
    "cheerio": "^1.2.0",
    "express": "^4.22.1",
    "youtubei.js": "^17.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  }
}
